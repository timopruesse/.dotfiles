#!/usr/bin/env python3
"""Generate platform-specific agent files from home/agents/*.md + model-map.yaml.

Sources use abstract `tier: cheap|mid|strong`. Outputs pin concrete models:

  home/.claude/agents/  — Claude Code (haiku / sonnet / opus)
  home/.cursor/agents/  — Cursor (Kimi / Composer fast / Grok fast)

Do not edit the generated trees by hand; re-run this script after editing sources.
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

AGENTS_DIR = Path(__file__).resolve().parent
REPO_HOME = AGENTS_DIR.parent  # home/
MAP_PATH = AGENTS_DIR / "model-map.yaml"
CLAUDE_OUT = REPO_HOME / ".claude" / "agents"
CURSOR_OUT = REPO_HOME / ".cursor" / "agents"
CURSOR_RULE = REPO_HOME / ".cursor" / "rules" / "subagent-model-fallback.mdc"
# Live Cursor config must not be replaced wholesale — only install agents/rules.
LIVE_CURSOR_AGENTS = Path.home() / ".cursor" / "agents"
LIVE_CURSOR_RULES = Path.home() / ".cursor" / "rules"

GENERATED_BANNER = (
    "<!-- Generated by home/agents/sync-agents — edit sources in home/agents/, "
    "not this file. -->\n"
)

FRONTMATTER_RE = re.compile(r"\A---\n(.*?)\n---\n(.*)\Z", re.DOTALL)


def parse_model_map(path: Path) -> dict[str, dict[str, str]]:
    """Parse the small fixed-shape model-map.yaml without PyYAML."""
    tiers: dict[str, dict[str, str]] = {}
    current: str | None = None
    in_tiers = False
    for raw in path.read_text().splitlines():
        line = raw.split("#", 1)[0].rstrip()
        if not line.strip():
            continue
        if line.strip() == "tiers:":
            in_tiers = True
            continue
        if not in_tiers:
            continue
        tier_m = re.match(r"^  (\w+):\s*$", line)
        if tier_m:
            current = tier_m.group(1)
            tiers[current] = {}
            continue
        pin_m = re.match(r"^    (claude|cursor):\s+(\S+)\s*$", line)
        if pin_m and current:
            tiers[current][pin_m.group(1)] = pin_m.group(2)
            continue
        raise SystemExit(f"unrecognized line in {path}: {raw!r}")
    for name, pins in tiers.items():
        if set(pins) != {"claude", "cursor"}:
            raise SystemExit(f"tier {name!r} missing claude/cursor pins: {pins}")
    return tiers


def split_agent(path: Path) -> tuple[dict[str, str], str]:
    text = path.read_text()
    m = FRONTMATTER_RE.match(text)
    if not m:
        raise SystemExit(f"{path}: missing YAML frontmatter")
    fm_raw, body = m.group(1), m.group(2)
    fields: dict[str, str] = {}
    key: str | None = None
    buf: list[str] = []

    def flush() -> None:
        nonlocal key, buf
        if key is None:
            return
        fields[key] = "\n".join(buf).rstrip("\n")
        key = None
        buf = []

    for line in fm_raw.splitlines():
        if line.startswith("  ") and key is not None:
            # continuation of a folded/block scalar started with >-
            buf.append(line)
            continue
        kv = re.match(r"^([A-Za-z0-9_]+):\s*(.*)$", line)
        if kv:
            flush()
            key = kv.group(1)
            rest = kv.group(2)
            if rest == ">-":
                buf = []
            elif rest == "|":
                buf = []
            else:
                buf = [rest]
            continue
        if key is not None and (line.startswith(" ") or line == ""):
            buf.append(line)
            continue
        raise SystemExit(f"{path}: cannot parse frontmatter line: {line!r}")
    flush()
    if "tier" not in fields:
        raise SystemExit(f"{path}: missing required `tier` field")
    if "name" not in fields:
        raise SystemExit(f"{path}: missing required `name` field")
    return fields, body


def render_frontmatter(fields: dict[str, str], model: str) -> str:
    lines = ["---"]
    order = ["name", "description", "model", "disallowedTools", "readonly", "is_background"]
    emitted = set()
    # Always emit name, description, model first in a stable order.
    for key in ("name", "description"):
        if key in fields:
            lines.append(_emit_field(key, fields[key]))
            emitted.add(key)
    lines.append(f"model: {model}")
    emitted.add("model")
    for key in order:
        if key in fields and key not in emitted and key != "tier":
            lines.append(_emit_field(key, fields[key]))
            emitted.add(key)
    for key, val in fields.items():
        if key in emitted or key == "tier":
            continue
        lines.append(_emit_field(key, val))
    lines.append("---")
    return "\n".join(lines) + "\n"


def _emit_field(key: str, value: str) -> str:
    if "\n" in value or value.startswith(">-") or (len(value) > 80 and " " in value):
        # Preserve folded block style for multi-line / long descriptions.
        if value.startswith(">-\n") or "\n" in value:
            # value already includes leading content lines from >- parse
            body_lines = value.split("\n")
            # If we stored without the >- marker, detect indentation style
            out = [f"{key}: >-"]
            for bl in body_lines:
                if bl == "":
                    out.append("")
                elif bl.startswith("  "):
                    out.append(bl)
                else:
                    out.append(f"  {bl}")
            return "\n".join(out)
        return f"{key}: >-\n  " + value.replace("\n", "\n  ")
    return f"{key}: {value}"


def write_agent(out_dir: Path, name: str, fields: dict[str, str], body: str, model: str) -> Path:
    out_dir.mkdir(parents=True, exist_ok=True)
    # Drop tier; pin model for this platform.
    # Banner must come AFTER frontmatter — parsers require --- at byte 0.
    body_out = body if body.startswith("\n") else "\n" + body
    content = render_frontmatter(fields, model) + GENERATED_BANNER + body_out
    if not content.endswith("\n"):
        content += "\n"
    path = out_dir / f"{name}.md"
    path.write_text(content)
    return path


def link_into(target: Path, link: Path) -> None:
    """Symlink `link` → `target`, replacing a prior symlink; refuse to clobber files."""
    link.parent.mkdir(parents=True, exist_ok=True)
    if link.is_symlink() or not link.exists():
        link.unlink(missing_ok=True)
        link.symlink_to(target)
        return
    raise SystemExit(
        f"refusing to replace non-symlink {link} (would install {target})"
    )


def install_live_cursor(agent_paths: list[Path], keep: set[str]) -> None:
    """Install generated Cursor agents + fallback rule into ~/.cursor without
    replacing the whole ~/.cursor tree (Cursor owns that directory)."""
    for path in agent_paths:
        link_into(path, LIVE_CURSOR_AGENTS / path.name)
    if LIVE_CURSOR_AGENTS.is_dir():
        for stale in LIVE_CURSOR_AGENTS.glob("*.md"):
            if stale.stem not in keep and stale.is_symlink():
                stale.unlink()
                print(f"  removed stale live link {stale}")
    if CURSOR_RULE.is_file():
        link_into(CURSOR_RULE, LIVE_CURSOR_RULES / CURSOR_RULE.name)
        print(f"  installed rule → {LIVE_CURSOR_RULES / CURSOR_RULE.name}")


def main() -> int:
    if not MAP_PATH.is_file():
        print(f"missing {MAP_PATH}", file=sys.stderr)
        return 1
    tiers = parse_model_map(MAP_PATH)
    sources = sorted(AGENTS_DIR.glob("*.md"))
    sources = [p for p in sources if p.name != "README.md"]
    if not sources:
        print(f"no agent sources in {AGENTS_DIR}", file=sys.stderr)
        return 1

    cursor_paths: list[Path] = []
    for src in sources:
        fields, body = split_agent(src)
        tier = fields["tier"].strip()
        if tier not in tiers:
            print(f"{src}: unknown tier {tier!r}; known: {sorted(tiers)}", file=sys.stderr)
            return 1
        name = fields["name"].strip()
        write_agent(CLAUDE_OUT, name, fields, body, tiers[tier]["claude"])
        cursor_paths.append(
            write_agent(CURSOR_OUT, name, fields, body, tiers[tier]["cursor"])
        )
        print(f"  {name}: tier={tier} → claude={tiers[tier]['claude']} cursor={tiers[tier]['cursor']}")

    # Remove stale generated agents not present in sources.
    keep = {p.stem for p in sources}
    for out_dir in (CLAUDE_OUT, CURSOR_OUT):
        if not out_dir.is_dir():
            continue
        for stale in out_dir.glob("*.md"):
            if stale.stem not in keep:
                stale.unlink()
                print(f"  removed stale {stale.relative_to(REPO_HOME)}")

    install_live_cursor(cursor_paths, keep)

    print(
        f"synced {len(sources)} agents → "
        f"{CLAUDE_OUT.relative_to(REPO_HOME.parent)} + "
        f"{CURSOR_OUT.relative_to(REPO_HOME.parent)} "
        f"(+ live {LIVE_CURSOR_AGENTS})"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
