#!/usr/bin/env python3
"""CLI: regenerate agent pins + tier catalog; optionally skip live install."""

from __future__ import annotations

import sys
from pathlib import Path

# Allow `from sync…` when invoked as ./home/agents/sync-agents
sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from sync.agents import sync_agents  # noqa: E402


def main() -> int:
    install_live = "--no-live" not in sys.argv
    return sync_agents(install_live=install_live)


if __name__ == "__main__":
    raise SystemExit(main())
