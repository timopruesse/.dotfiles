#!/usr/bin/env python3
"""Generate platform-specific slash commands from home/commands/*.md.

Sources keep Claude-style frontmatter + `$ARGUMENTS`. Outputs:

  home/.claude/commands/  — frontmatter + `$ARGUMENTS` (Claude Code)
  home/.cursor/commands/  — plain markdown + positional `$1`/`$2`/… (Cursor)

Also installs live symlinks into ~/.cursor/commands/ and keeps protocol
symlinks under home/.claude/ → home/protocols/.

Do not edit the generated trees by hand; re-run after editing sources.
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

COMMANDS_DIR = Path(__file__).resolve().parent
REPO_HOME = COMMANDS_DIR.parent  # home/
PROTOCOLS_DIR = REPO_HOME / "protocols"
CLAUDE_OUT = REPO_HOME / ".claude" / "commands"
CURSOR_OUT = REPO_HOME / ".cursor" / "commands"
CLAUDE_ROOT = REPO_HOME / ".claude"
CURSOR_PROTOCOLS = REPO_HOME / ".cursor" / "protocols"
LIVE_CURSOR_COMMANDS = Path.home() / ".cursor" / "commands"

GENERATED_BANNER = (
    "<!-- Generated by home/commands/sync-commands — edit sources in "
    "home/commands/, not this file. -->\n"
)

FRONTMATTER_RE = re.compile(r"\A---\n(.*?)\n---\n(.*)\Z", re.DOTALL)

CURSOR_ARGS_PREAMBLE = """\
## Arguments (Cursor)

Positional args from the slash invocation: `$1`, `$2`, `$3`, … .
When this prompt mentions `$ARGUMENTS`, treat it as the joined remainder
`"$1 $2 $3 …"` (trim; empty if no args). Multi-token parsers (e.g. `/dispatch`)
still apply: `$1` = first token (key), later tokens / flags as documented below.

"""


def split_command(path: Path) -> tuple[str, str]:
    text = path.read_text()
    m = FRONTMATTER_RE.match(text)
    if not m:
        raise SystemExit(f"{path}: missing YAML frontmatter")
    return m.group(1), m.group(2)


def rewrite_protocol_links_for_claude(body: str) -> str:
    """Prefer ~/protocols/ absolute paths; keep relative ../protocols/ ok."""
    body = body.replace("`~/.claude/LOOP-PROTOCOL.md`", "`~/protocols/LOOP-PROTOCOL.md`")
    body = body.replace("`~/.claude/HANDOFF-PROTOCOL.md`", "`~/protocols/HANDOFF-PROTOCOL.md`")
    return body


def to_cursor_body(body: str) -> str:
    body = rewrite_protocol_links_for_claude(body)
    # Relative links from .claude/commands → protocols become absolute for Cursor
    body = re.sub(
        r"\]\(\.\./protocols/(HANDOFF-PROTOCOL|LOOP-PROTOCOL)\.md\)",
        r"](~/protocols/\1.md)",
        body,
    )
    # Keep $ARGUMENTS in prose but Cursor preamble explains the mapping.
    # Also rewrite explicit "$ARGUMENTS" in ScheduleWakeup examples to joined form.
    return CURSOR_ARGS_PREAMBLE + body


def write_claude(name: str, fm: str, body: str) -> Path:
    CLAUDE_OUT.mkdir(parents=True, exist_ok=True)
    body = rewrite_protocol_links_for_claude(body)
    if not body.startswith("\n"):
        body = "\n" + body
    content = f"---\n{fm}\n---\n{GENERATED_BANNER}{body}"
    if not content.endswith("\n"):
        content += "\n"
    path = CLAUDE_OUT / f"{name}.md"
    path.write_text(content)
    return path


def write_cursor(name: str, body: str) -> Path:
    CURSOR_OUT.mkdir(parents=True, exist_ok=True)
    body = to_cursor_body(body)
    if not body.endswith("\n"):
        body += "\n"
    # Cursor: no frontmatter. Banner first is fine (plain markdown).
    content = GENERATED_BANNER + "\n" + body
    path = CURSOR_OUT / f"{name}.md"
    path.write_text(content)
    return path


def link_into(target: Path, link: Path, *, replace_file: bool = False) -> None:
    link.parent.mkdir(parents=True, exist_ok=True)
    if link.is_symlink() or not link.exists():
        link.unlink(missing_ok=True)
        link.symlink_to(target)
        return
    if replace_file and link.is_file() and not link.is_symlink():
        link.unlink()
        link.symlink_to(target)
        return
    raise SystemExit(f"refusing to replace non-symlink {link} (would install {target})")


def install_protocols() -> None:
    """Point .claude and .cursor protocol paths at home/protocols/."""
    for name in ("HANDOFF-PROTOCOL.md", "LOOP-PROTOCOL.md"):
        src = PROTOCOLS_DIR / name
        if not src.is_file():
            raise SystemExit(f"missing protocol {src}")
        # Repo-owned .claude copies become symlinks into ../protocols/
        link_into(src, CLAUDE_ROOT / name, replace_file=True)
        link_into(src, CURSOR_PROTOCOLS / name, replace_file=True)
    # So `~/protocols/…` resolves even when home/ isn't bulk-symlinked to ~.
    live_protocols = Path.home() / "protocols"
    link_into(PROTOCOLS_DIR, live_protocols, replace_file=False)


def install_live_cursor(paths: list[Path], keep: set[str]) -> None:
    for path in paths:
        link_into(path, LIVE_CURSOR_COMMANDS / path.name)
    if LIVE_CURSOR_COMMANDS.is_dir():
        for stale in LIVE_CURSOR_COMMANDS.glob("*.md"):
            if stale.stem not in keep and stale.is_symlink():
                stale.unlink()
                print(f"  removed stale live link {stale}")


def main() -> int:
    if not PROTOCOLS_DIR.is_dir():
        print(f"missing {PROTOCOLS_DIR}", file=sys.stderr)
        return 1
    sources = sorted(p for p in COMMANDS_DIR.glob("*.md") if p.name != "README.md")
    if not sources:
        print(f"no command sources in {COMMANDS_DIR}", file=sys.stderr)
        return 1

    install_protocols()

    cursor_paths: list[Path] = []
    for src in sources:
        fm, body = split_command(src)
        name = src.stem
        write_claude(name, fm, body)
        cursor_paths.append(write_cursor(name, body))
        print(f"  {name}")

    keep = {p.stem for p in sources}
    for out_dir in (CLAUDE_OUT, CURSOR_OUT):
        if not out_dir.is_dir():
            continue
        for stale in out_dir.glob("*.md"):
            if stale.stem not in keep:
                stale.unlink()
                print(f"  removed stale {stale.relative_to(REPO_HOME)}")

    install_live_cursor(cursor_paths, keep)
    print(
        f"synced {len(sources)} commands → "
        f"{CLAUDE_OUT.relative_to(REPO_HOME.parent)} + "
        f"{CURSOR_OUT.relative_to(REPO_HOME.parent)} "
        f"(+ live {LIVE_CURSOR_COMMANDS})"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
