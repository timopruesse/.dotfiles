#!/usr/bin/env python3
"""CLI: regenerate slash commands + protocols; optionally skip live install."""

from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from sync.commands import sync_commands  # noqa: E402


def main() -> int:
    install_live = "--no-live" not in sys.argv
    return sync_commands(install_live=install_live)


if __name__ == "__main__":
    raise SystemExit(main())
