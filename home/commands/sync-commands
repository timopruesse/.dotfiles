#!/usr/bin/env python3
"""Generate platform-specific slash commands from home/commands/*.md.

Sources keep Claude-style frontmatter + `$ARGUMENTS`, with abstract
`tier: cheap|mid|strong` (same map as agents). Outputs:

  home/.claude/commands/  — frontmatter + `model:` pin + `$ARGUMENTS` (Claude Code)
  home/.cursor/commands/  — plain markdown + positional `$1`/`$2`/… + model note

Also installs live symlinks into ~/.cursor/commands/ and keeps protocol
symlinks under home/.claude/ → home/protocols/.

Do not edit the generated trees by hand; re-run after editing sources.
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

COMMANDS_DIR = Path(__file__).resolve().parent
REPO_HOME = COMMANDS_DIR.parent  # home/
PROTOCOLS_DIR = REPO_HOME / "protocols"
MAP_PATH = REPO_HOME / "agents" / "model-map.yaml"
CLAUDE_OUT = REPO_HOME / ".claude" / "commands"
CURSOR_OUT = REPO_HOME / ".cursor" / "commands"
CLAUDE_ROOT = REPO_HOME / ".claude"
CURSOR_PROTOCOLS = REPO_HOME / ".cursor" / "protocols"
LIVE_CURSOR_COMMANDS = Path.home() / ".cursor" / "commands"

GENERATED_BANNER = (
    "<!-- Generated by home/commands/sync-commands — edit sources in "
    "home/commands/, not this file. -->\n"
)

FRONTMATTER_RE = re.compile(r"\A---\n(.*?)\n---\n(.*)\Z", re.DOTALL)

# Fields emitted into Claude frontmatter, in stable order. `tier` is source-only.
CLAUDE_FM_ORDER = ("description", "argument-hint", "model", "allowed-tools", "disable-model-invocation")


def parse_model_map(path: Path) -> dict[str, dict[str, str]]:
    """Parse the small fixed-shape model-map.yaml without PyYAML."""
    tiers: dict[str, dict[str, str]] = {}
    current: str | None = None
    in_tiers = False
    for raw in path.read_text().splitlines():
        line = raw.split("#", 1)[0].rstrip()
        if not line.strip():
            continue
        if line.strip() == "tiers:":
            in_tiers = True
            continue
        if not in_tiers:
            continue
        tier_m = re.match(r"^  (\w+):\s*$", line)
        if tier_m:
            current = tier_m.group(1)
            tiers[current] = {}
            continue
        pin_m = re.match(r"^    (claude|cursor):\s+(\S+)\s*$", line)
        if pin_m and current:
            tiers[current][pin_m.group(1)] = pin_m.group(2)
            continue
        raise SystemExit(f"unrecognized line in {path}: {raw!r}")
    for name, pins in tiers.items():
        if set(pins) != {"claude", "cursor"}:
            raise SystemExit(f"tier {name!r} missing claude/cursor pins: {pins}")
    return tiers


def split_command(path: Path) -> tuple[dict[str, str], str]:
    text = path.read_text()
    m = FRONTMATTER_RE.match(text)
    if not m:
        raise SystemExit(f"{path}: missing YAML frontmatter")
    fm_raw, body = m.group(1), m.group(2)
    fields: dict[str, str] = {}
    for line in fm_raw.splitlines():
        if not line.strip():
            continue
        kv = re.match(r"^([A-Za-z0-9_-]+):\s*(.*)$", line)
        if not kv:
            raise SystemExit(f"{path}: cannot parse frontmatter line: {line!r}")
        fields[kv.group(1)] = kv.group(2)
    if "tier" not in fields:
        raise SystemExit(f"{path}: missing required `tier` field (cheap|mid|strong)")
    if "description" not in fields:
        raise SystemExit(f"{path}: missing required `description` field")
    return fields, body


def render_claude_frontmatter(fields: dict[str, str], model: str) -> str:
    lines = ["---"]
    emitted: set[str] = set()
    for key in CLAUDE_FM_ORDER:
        if key == "model":
            lines.append(f"model: {model}")
            emitted.add("model")
            continue
        if key in fields:
            lines.append(f"{key}: {fields[key]}")
            emitted.add(key)
    for key, val in fields.items():
        if key in emitted or key == "tier":
            continue
        lines.append(f"{key}: {val}")
    lines.append("---")
    return "\n".join(lines) + "\n"


def rewrite_protocol_links_for_claude(body: str) -> str:
    """Prefer ~/protocols/ absolute paths; keep relative ../protocols/ ok."""
    body = body.replace("`~/.claude/LOOP-PROTOCOL.md`", "`~/protocols/LOOP-PROTOCOL.md`")
    body = body.replace("`~/.claude/HANDOFF-PROTOCOL.md`", "`~/protocols/HANDOFF-PROTOCOL.md`")
    return body


def cursor_preamble(cursor_model: str, tier: str) -> str:
    return (
        f"## Orchestrator model (Cursor)\n"
        f"\n"
        f"Preferred session model for this command: `{cursor_model}` "
        f"(tier `{tier}` via `home/agents/model-map.yaml`). "
        f"Cursor slash commands inherit the chat model — switch the model "
        f"picker to that pin before invoking if the session is on a stronger "
        f"tier. Subagents keep their own frontmatter pins.\n"
        f"\n"
        f"## Arguments (Cursor)\n"
        f"\n"
        f"Positional args from the slash invocation: `$1`, `$2`, `$3`, … .\n"
        f"When this prompt mentions `$ARGUMENTS`, treat it as the joined remainder\n"
        f"`\"$1 $2 $3 …\"` (trim; empty if no args). Multi-token parsers (e.g. `/dispatch`)\n"
        f"still apply: `$1` = first token (key), later tokens / flags as documented below.\n"
        f"\n"
    )


def to_cursor_body(body: str, cursor_model: str, tier: str) -> str:
    body = rewrite_protocol_links_for_claude(body)
    # Relative links from .claude/commands → protocols become absolute for Cursor
    body = re.sub(
        r"\]\(\.\./protocols/(HANDOFF-PROTOCOL|LOOP-PROTOCOL)\.md\)",
        r"](~/protocols/\1.md)",
        body,
    )
    return cursor_preamble(cursor_model, tier) + body


def write_claude(name: str, fields: dict[str, str], body: str, model: str) -> Path:
    CLAUDE_OUT.mkdir(parents=True, exist_ok=True)
    body = rewrite_protocol_links_for_claude(body)
    if not body.startswith("\n"):
        body = "\n" + body
    content = render_claude_frontmatter(fields, model) + GENERATED_BANNER + body
    if not content.endswith("\n"):
        content += "\n"
    path = CLAUDE_OUT / f"{name}.md"
    path.write_text(content)
    return path


def write_cursor(name: str, body: str, cursor_model: str, tier: str) -> Path:
    CURSOR_OUT.mkdir(parents=True, exist_ok=True)
    body = to_cursor_body(body, cursor_model, tier)
    if not body.endswith("\n"):
        body += "\n"
    # Cursor: no YAML frontmatter (treated as prompt). Banner first is fine.
    content = GENERATED_BANNER + "\n" + body
    path = CURSOR_OUT / f"{name}.md"
    path.write_text(content)
    return path


def link_into(target: Path, link: Path, *, replace_file: bool = False) -> None:
    link.parent.mkdir(parents=True, exist_ok=True)
    if link.is_symlink() or not link.exists():
        link.unlink(missing_ok=True)
        link.symlink_to(target)
        return
    if replace_file and link.is_file() and not link.is_symlink():
        link.unlink()
        link.symlink_to(target)
        return
    raise SystemExit(f"refusing to replace non-symlink {link} (would install {target})")


def install_protocols() -> None:
    """Point .claude and .cursor protocol paths at home/protocols/."""
    for name in ("HANDOFF-PROTOCOL.md", "LOOP-PROTOCOL.md"):
        src = PROTOCOLS_DIR / name
        if not src.is_file():
            raise SystemExit(f"missing protocol {src}")
        # Repo-owned .claude copies become symlinks into ../protocols/
        link_into(src, CLAUDE_ROOT / name, replace_file=True)
        link_into(src, CURSOR_PROTOCOLS / name, replace_file=True)
    # So `~/protocols/…` resolves even when home/ isn't bulk-symlinked to ~.
    live_protocols = Path.home() / "protocols"
    link_into(PROTOCOLS_DIR, live_protocols, replace_file=False)


def install_live_cursor(paths: list[Path], keep: set[str]) -> None:
    for path in paths:
        link_into(path, LIVE_CURSOR_COMMANDS / path.name)
    if LIVE_CURSOR_COMMANDS.is_dir():
        for stale in LIVE_CURSOR_COMMANDS.glob("*.md"):
            if stale.stem not in keep and stale.is_symlink():
                stale.unlink()
                print(f"  removed stale live link {stale}")


def main() -> int:
    if not PROTOCOLS_DIR.is_dir():
        print(f"missing {PROTOCOLS_DIR}", file=sys.stderr)
        return 1
    if not MAP_PATH.is_file():
        print(f"missing {MAP_PATH}", file=sys.stderr)
        return 1
    tiers = parse_model_map(MAP_PATH)

    sources = sorted(p for p in COMMANDS_DIR.glob("*.md") if p.name != "README.md")
    if not sources:
        print(f"no command sources in {COMMANDS_DIR}", file=sys.stderr)
        return 1

    install_protocols()

    cursor_paths: list[Path] = []
    for src in sources:
        fields, body = split_command(src)
        tier = fields["tier"].strip()
        if tier not in tiers:
            print(f"{src}: unknown tier {tier!r}; known: {sorted(tiers)}", file=sys.stderr)
            return 1
        name = src.stem
        claude_model = tiers[tier]["claude"]
        cursor_model = tiers[tier]["cursor"]
        write_claude(name, fields, body, claude_model)
        cursor_paths.append(write_cursor(name, body, cursor_model, tier))
        print(f"  {name}: tier={tier} → claude={claude_model} cursor={cursor_model}")

    keep = {p.stem for p in sources}
    for out_dir in (CLAUDE_OUT, CURSOR_OUT):
        if not out_dir.is_dir():
            continue
        for stale in out_dir.glob("*.md"):
            if stale.stem not in keep:
                stale.unlink()
                print(f"  removed stale {stale.relative_to(REPO_HOME)}")

    install_live_cursor(cursor_paths, keep)
    print(
        f"synced {len(sources)} commands → "
        f"{CLAUDE_OUT.relative_to(REPO_HOME.parent)} + "
        f"{CURSOR_OUT.relative_to(REPO_HOME.parent)} "
        f"(+ live {LIVE_CURSOR_COMMANDS})"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
